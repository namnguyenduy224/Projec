package ui;
import java.util.Scanner;
import services.BrewingService;

public class MenuCongThucPhaTra {
    private BrewingService brewingService;
    private Scanner sc = new Scanner(System.in);

    public MenuCongThucPhaTra(BrewingService brewingService) {
        this.brewingService = brewingService;
    }

    public void hienThi() {
        int choice;
        do {
            Utils.printHeader("MENU CÔNG THỨC PHA TRÀ");
            Utils.printOption(1, "Xem tất cả công thức (phân trang)");
            Utils.printOption(2, "Thêm công thức mới");
            Utils.printOption(3, "Xem chi tiết công thức");
            Utils.printOption(4, "Chỉnh sửa công thức");
            Utils.printOption(5, "Xóa công thức");
            Utils.printOption(6, "Thử pha trà theo công thức");
            Utils.printOption(0, "Quay lại Menu Chính");
            Utils.printFooter();
            System.out.print("Chọn → ");
            choice = sc.nextInt(); sc.nextLine();

            switch (choice) {
                case 1: brewingService.hienThiTatCaCongThuc(); break;
                case 2: brewingService.themCongThuc(); break;
                case 3: brewingService.xemChiTiet(); break;
                case 4: brewingService.capNhatCongThuc(); break;
                case 5: brewingService.xoaCongThuc(); break;
                case 6: brewingService.thuPhaTra(); break;
                case 0: System.out.println(Utils.GREEN + "← Quay lại..." + Utils.RESET); break;
                default: System.out.println(Utils.RED + "❌ Sai lựa chọn!" + Utils.RESET);
            }
        } while (choice != 0);
    }
}
