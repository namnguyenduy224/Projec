    // Hàm hỗ trợ nhập số an toàn
    private int nhapSo() {
        while (!scanner.hasNextInt()) {
            System.out.print("Vui lòng nhập một số: ");
            scanner.next();
        }
        int so = scanner.nextInt();
        scanner.nextLine(); // xóa dòng thừa
        return so;
    }

    private void clearScreen() {
        System.out.print("\033[H\033[2J");  // Xóa màn hình (có thể không hoạt động trên mọi máy)
        System.out.flush();
